#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Install the repo-managed pre-push guard into the current Git repository.

repo_root="$(git rev-parse --show-toplevel)"
guard_path="${repo_root}/bin/git-branch-publication-guard"
hook_path="$(git rev-parse --git-path hooks/pre-push)"
managed_marker="# dotfiles managed branch publication guard"
next_hook_path="${hook_path}.dotfiles-next"

if [[ ! -x ${guard_path} ]]; then
  echo "Warning: branch publication guard is not executable: ${guard_path}" >&2
  exit 0
fi

mkdir -p "$(dirname "${hook_path}")"

if [[ -e ${hook_path} ]] && ! grep -Fq "${managed_marker}" "${hook_path}"; then
  mv "${hook_path}" "${next_hook_path}"
elif [[ ! -e ${hook_path} ]]; then
  rm -f "${next_hook_path}"
fi

tmp_hook="${hook_path}.tmp.$$"
cat >"${tmp_hook}" <<'HOOK'
#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# dotfiles managed branch publication guard
repo_root="$(git rev-parse --show-toplevel)"
hook_dir="$(cd "$(dirname "$0")" && pwd -P)"
next_hook="${hook_dir}/pre-push.dotfiles-next"
stdin_file="$(mktemp "${TMPDIR:-/tmp}/dotfiles-pre-push.XXXXXX")"

cleanup() {
  rm -f "${stdin_file}"
}
trap cleanup EXIT

cat >"${stdin_file}"

"${repo_root}/bin/git-branch-publication-guard" "$@" <"${stdin_file}"

if [[ -x ${next_hook} ]]; then
  "${next_hook}" "$@" <"${stdin_file}"
fi
HOOK

chmod 0755 "${tmp_hook}"
mv "${tmp_hook}" "${hook_path}"
echo "* Installed branch publication guard: ${hook_path}"
