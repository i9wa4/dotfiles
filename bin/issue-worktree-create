#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Create a git worktree for the specified GitHub issue(s).
# Uses Claude to generate a descriptive branch name from the issue content.
# Falls back to title-based naming if Claude is not available.
#
# Usage:
#   issue-worktree-create [--allow-direnv] <issue_number> [issue_number2 ...]
#
# Dependencies:
#   - gh (GitHub CLI)
#   - jq
#   - claude (Anthropic CLI, optional)
#   - repo-setup (optional)
#   - direnv (optional; only for --allow-direnv)

# Check required dependencies
for cmd in gh jq git; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd command not found. Please install it." >&2
    exit 1
  fi
done

allow_direnv="false"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --allow-direnv)
      allow_direnv="true"
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Error: unknown option: $1" >&2
      echo "Usage: $0 [--allow-direnv] <issue_number> [issue_number2 ...]" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

# Check arguments
if [[ $# -eq 0 ]]; then
  echo "Usage: $0 [--allow-direnv] <issue_number> [issue_number2 ...]" >&2
  echo "Example: $0 123" >&2
  echo "Example: $0 --allow-direnv 123" >&2
  echo "Example: $0 123 456 789" >&2
  exit 1
fi

# Get repository root
repo_root=$(git rev-parse --show-toplevel)

find_worktree_for_branch() {
  local branch=$1
  local target_ref="refs/heads/${branch}"

  git worktree list --porcelain | awk -v target_ref="$target_ref" '
    /^worktree / {
      path = substr($0, 10)
    }
    /^branch / {
      if (substr($0, 8) == target_ref) {
        print path
        found = 1
      }
    }
    END {
      exit found ? 0 : 1
    }
  '
}

ensure_remote_tracking_branch() {
  local branch=$1
  local upstream="origin/${branch}"

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    git branch --set-upstream-to="${upstream}" "${branch}"
  else
    git branch --track "${branch}" "${upstream}"
  fi
}

# Fetch remote and update main branch
echo "-> Fetching remote..."
git fetch origin
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [[ "$current_branch" == "main" ]]; then
  git pull --ff-only origin main
else
  echo "* Keeping local main unchanged while ${current_branch} is checked out"
fi
echo ""

# Process each issue number
for issue_number in "$@"; do
  # Validate issue number
  if [[ ! $issue_number =~ ^[0-9]+$ ]]; then
    echo "Warning: '$issue_number' is not a valid issue number. Skipping." >&2
    echo ""
    continue
  fi

  echo "=== Processing Issue #${issue_number} ==="

  # Fetch issue information
  echo "-> Fetching issue info..."
  if ! issue_json=$(gh issue view "${issue_number}" --json title,body,comments 2>&1); then
    echo "Error: Failed to fetch Issue #${issue_number}. Skipping." >&2
    echo "${issue_json}" >&2
    echo ""
    continue
  fi

  issue_title=$(jq -r '.title // empty' <<<"$issue_json")
  issue_body=$(jq -r '.body // empty' <<<"$issue_json")
  issue_comments=$(jq -r '.comments[]?.body // empty' <<<"$issue_json" | head -c 2000)

  if [[ -z $issue_title ]]; then
    echo "Error: Issue #${issue_number} has no title. Skipping." >&2
    echo ""
    continue
  fi

  # Check for existing remote branch with issue number prefix
  echo "-> Checking for existing remote branch..."
  existing_branch=""
  if git show-ref --verify --quiet "refs/remotes/origin/issue-${issue_number}"; then
    existing_branch="issue-${issue_number}"
  else
    existing_branch=$(git branch -r --list "origin/issue-${issue_number}-*" | head -n 1 | sed 's|^[[:space:]]*origin/||')
  fi

  if [[ -n $existing_branch ]]; then
    echo "  Found existing remote branch: ${existing_branch}"
    branch_name="$existing_branch"
  else
    # Generate branch name
    echo "-> Generating branch name..."
    branch_slug=""

    # Try Claude first if available
    if command -v claude &>/dev/null; then
      prompt="Generate a short English slug (kebab-case) for a Git branch name from the following issue.
- Maximum 5 words
- Lowercase alphabet, number and hyphens only
- Remove special characters
- Start with a verb if possible

Return ONLY the slug (no explanation).

---
Issue title: ${issue_title}
---
Issue body:
${issue_body}
---
Issue comments:
${issue_comments}
---"

      branch_slug=$(claude --print \
        --system-prompt "Output ONLY the raw slug. No decorations, insights, or explanations." \
        "$prompt" 2>/dev/null \
        | tail -n 1 \
        | tr '[:upper:]' '[:lower:]' \
        | tr -cd 'a-z0-9-' \
        | sed 's/--*/-/g; s/^-//; s/-$//' \
        | cut -c 1-50) || true
    fi

    # Fallback: use issue number only
    if [[ -z $branch_slug ]]; then
      echo "  (Using fallback: issue number only)"
      branch_name="issue-${issue_number}"
    else
      branch_name="issue-${issue_number}-${branch_slug}"
    fi
  fi
  echo "* Branch name: ${branch_name}"

  worktree_name="${branch_name//\//-}"
  desired_worktree_path="${repo_root}/.worktrees/${worktree_name}"
  existing_worktree_path=""
  if existing_worktree_path=$(find_worktree_for_branch "${branch_name}" 2>/dev/null); then
    :
  else
    existing_worktree_path=""
  fi

  if git ls-remote --exit-code --heads origin "${branch_name}" >/dev/null 2>&1; then
    branch_origin="remote"
    if ! git fetch origin "+refs/heads/${branch_name}:refs/remotes/origin/${branch_name}"; then
      echo "Error: Could not fetch origin/${branch_name}. Skipping." >&2
      echo ""
      continue
    fi
    if ! ensure_remote_tracking_branch "${branch_name}"; then
      echo "Error: Could not connect local branch to origin/${branch_name}. Skipping." >&2
      echo ""
      continue
    fi
  elif git show-ref --verify --quiet "refs/heads/${branch_name}"; then
    branch_origin="local"
  else
    branch_origin="new"
  fi

  if [[ -n $existing_worktree_path ]]; then
    worktree_path=$existing_worktree_path
  else
    mkdir -p "${repo_root}/.worktrees"
    if [[ -e $desired_worktree_path ]]; then
      echo "Error: desired issue worktree path already exists: ${desired_worktree_path}" >&2
      echo ""
      continue
    fi

    case "${branch_origin}" in
      remote | local)
        if ! git worktree add "${desired_worktree_path}" "${branch_name}"; then
          echo "Error: Could not prepare worktree for '${branch_name}' at '${desired_worktree_path}'." >&2
          echo ""
          continue
        fi
        ;;
      new)
        if ! git worktree add -b "${branch_name}" "${desired_worktree_path}" main; then
          echo "Error: Could not create worktree for '${branch_name}' at '${desired_worktree_path}'." >&2
          echo ""
          continue
        fi
        ;;
    esac

    worktree_path=$desired_worktree_path
  fi

  if [[ -n $existing_worktree_path ]]; then
    echo "* Worktree already exists: ${worktree_path}"
    echo "* Branch: ${branch_name}"
  else
    echo "* Created worktree: ${worktree_path}"

    case "${branch_origin}" in
      remote)
        echo "* Using remote branch: ${branch_name}"
        ;;
      local)
        echo "* Using existing local branch: ${branch_name}"
        ;;
      new)
        echo "* Created local branch: ${branch_name} (from main)"
        ;;
    esac

    # Copy .envrc if it exists
    if [[ -f "${repo_root}/.envrc" ]]; then
      cp "${repo_root}/.envrc" "${worktree_path}/.envrc"
      echo "* Copied .envrc to worktree"
    fi

    # Run repo-setup if available
    if command -v repo-setup &>/dev/null; then
      echo "-> Running repo-setup..."
      cd "$worktree_path"
      if [[ ${allow_direnv} == "true" ]]; then
        repo-setup --allow-direnv
      else
        repo-setup
      fi
      cd - >/dev/null
    fi
  fi

  if command -v zoxide &>/dev/null; then
    zoxide add "$worktree_path"
    echo "* Added worktree to zoxide database"
  fi

  echo ""
done

echo "* All issue worktrees are ready."
echo ""
