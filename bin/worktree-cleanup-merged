#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# List vde-worktrees across ghq repositories with status metadata and delete
# merged cleanup candidates only after explicit confirmation.

usage() {
  cat <<'EOF'
Usage:
  worktree-cleanup-merged [--dry-run] [--yes]

Options:
  --dry-run  List candidates without prompting or deleting.
  --yes      Delete without prompting.
  -h, --help Show this help.
EOF
}

dry_run=false
assume_yes=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=true
      ;;
    --yes)
      assume_yes=true
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

for cmd in ghq jq vde-worktree; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: $cmd command not found. Please install it." >&2
    exit 1
  fi
done

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

repos_file="${tmpdir}/repos.tsv"
candidates_file="${tmpdir}/candidates.tsv"
inventory_file="${tmpdir}/inventory.tsv"
repos_apply_file="${tmpdir}/repos-apply.txt"
gone_json_file="${tmpdir}/gone.json"
list_json_file="${tmpdir}/list.json"

ghq list -p >"$repos_file"
: >"$candidates_file"
: >"$inventory_file"

while IFS= read -r repo; do
  [[ -n $repo ]] || continue
  [[ $repo != *"/.worktrees/"* ]] || continue
  [[ -d "${repo}/.git" || -f "${repo}/.git" ]] || continue
  [[ -d "${repo}/.worktrees" || -d "${repo}/.vde" || -f "${repo}/config/vde/worktree/config.yml" ]] || continue

  if ! gone_json=$({ cd "$repo" && vde-worktree gone --json; } 2>/dev/null); then
    echo "Warning: failed to inspect ${repo}" >&2
    continue
  fi

  printf '%s\n' "$gone_json" >"$gone_json_file"
  if ! list_json=$({ cd "$repo" && vde-worktree list --json; } 2>/dev/null); then
    list_json='{"worktrees":[]}'
  fi
  printf '%s\n' "$list_json" >"$list_json_file"

  jq -r --arg repo "$repo" --slurpfile gone "$gone_json_file" '
    def mark($value; $yes; $no): if $value then $yes else $no end;
    ($gone[0].candidates // []) as $candidates
    | .worktrees[]?
    | select(.branch != null)
    | . as $worktree
    | [
        $repo,
        ($worktree.branch // ""),
        ($worktree.path // ""),
        mark($candidates | index($worktree.branch); "🧹"; "・"),
        mark($worktree.merged.overall // false; "✅"; "・"),
        mark($worktree.dirty // false; "⚠️"; "・"),
        mark($worktree.locked.value // false; "🔒"; "・"),
        ($worktree.pr.status // "none"),
        ($worktree.upstream.remote // "")
      ] | @tsv
  ' "$list_json_file" >>"$inventory_file"

  jq -r --arg repo "$repo" --slurpfile gone "$gone_json_file" '
    ($gone[0].candidates // []) as $candidates
    | .worktrees[]?
    | select(.branch as $branch | $candidates | index($branch))
    | [$repo, .branch, (.path // "")] | @tsv
  ' "$list_json_file" >>"$candidates_file"
done <"$repos_file"

worktree_count=$(wc -l <"$inventory_file" | tr -d '[:space:]')
candidate_count=$(wc -l <"$candidates_file" | tr -d '[:space:]')

bold=""
reset=""
if [[ -t 1 ]]; then
  bold=$'\033[1m'
  reset=$'\033[0m'
fi

if [[ $worktree_count -eq 0 ]]; then
  echo "No managed worktrees found."
  exit 0
fi

echo "Managed worktrees:"
echo ""
awk -F '\t' -v bold="$bold" -v reset="$reset" '
  function shorten(value, width) {
    if (length(value) <= width) {
      return value
    }
    return substr(value, 1, width - 1) "…"
  }
  function row_style(cleanup) {
    return cleanup == "🧹" ? bold : ""
  }
  BEGIN {
    printf "%-4s  %-2s %-2s %-2s %-2s  %-15s  %-38s  %s\n",
      "No.", "C", "M", "D", "L", "PR", "Branch", "Path"
    printf "%-4s  %-2s %-2s %-2s %-2s  %-15s  %-38s  %s\n",
      "---", "-", "-", "-", "-", "--", "------", "----"
  }
  {
    upstream = $9 == "" ? "" : " upstream=" $9
    style = row_style($4)
    end_style = style == "" ? "" : reset
    printf "%s%-4d  %-2s %-2s %-2s %-2s  %-15s  %-38s  %s%s%s\n",
      style,
      NR, $4, $5, $6, $7, $8, shorten($2, 38), $3, upstream,
      end_style
  }
' "$inventory_file"
echo ""
echo "Legend: C=cleanup candidate, M=merged, D=dirty, L=locked"
echo "        🧹=candidate, ✅=merged, ⚠️=dirty, 🔒=locked, ・=no"
if [[ -n $bold ]]; then
  echo "        candidate rows are bold"
fi
echo ""
echo "Worktrees: ${worktree_count}"

if [[ $candidate_count -eq 0 ]]; then
  echo "Cleanup candidates: 0"
  echo "No merged worktree cleanup candidates found."
  exit 0
fi

echo "Cleanup candidates: ${candidate_count}"
echo ""
awk -F '\t' '
  {
    printf "%2d. %s\n    branch: %s\n    path:   %s\n", NR, $1, $2, $3
  }
' "$candidates_file"
echo ""
echo "Total: ${candidate_count}"

if [[ $dry_run == "true" ]]; then
  exit 0
fi

if [[ $assume_yes != "true" ]]; then
  if [[ ! -t 0 ]]; then
    echo "Refusing to delete without a TTY. Re-run with --yes if this is intended." >&2
    exit 2
  fi

  printf 'Delete these merged worktrees? Type yes to continue: '
  IFS= read -r answer
  if [[ $answer != "yes" ]]; then
    echo "Cancelled."
    exit 0
  fi
fi

cut -f 1 "$candidates_file" | sort -u >"$repos_apply_file"

while IFS= read -r repo; do
  [[ -n $repo ]] || continue
  echo "-> Cleaning ${repo}"
  { cd "$repo" && vde-worktree gone --apply; }
done <"$repos_apply_file"

if command -v zoxide >/dev/null 2>&1; then
  while IFS=$'\t' read -r _repo _branch path; do
    [[ -n $path ]] || continue
    zoxide remove "$path" >/dev/null 2>&1 || true
  done <"$candidates_file"
fi

echo "Done."
