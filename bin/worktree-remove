#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Select and remove one managed worktree from the current repository.
# Removal uses git worktree directly and refuses dirty, locked, or unmerged
# branch worktrees before deleting anything.

usage() {
  cat <<'EOF'
Usage:
  worktree-remove

Search the current repository's .worktrees/ directory for managed worktrees,
select one with fzf, confirm by typing "yes", then remove it with git
worktree remove.

Options:
  -h, --help  Show this help.
EOF
}

require_command() {
  local command_name="$1"

  if ! command -v "$command_name" &>/dev/null; then
    echo "Error: ${command_name} command not found. Please install it." >&2
    exit 1
  fi
}

path_basename() {
  local path="$1"

  path="${path%/}"
  printf '%s\n' "${path##*/}"
}

extract_prefixed_number() {
  local value="$1"
  local prefix="$2"
  local rest
  local number

  case "$value" in
    "${prefix}-"[0-9]*)
      rest="${value#"${prefix}-"}"
      number="${rest%%-*}"
      case "$number" in
        "" | *[!0-9]*)
          return 1
          ;;
        *)
          printf '%s\n' "$number"
          ;;
      esac
      ;;
    *)
      return 1
      ;;
  esac
}

classify_worktree() {
  local branch="$1"
  local worktree_path="$2"
  local worktree_name
  local number

  worktree_name=$(path_basename "$worktree_path")

  if number=$(extract_prefixed_number "$worktree_name" "pr"); then
    printf 'pr\t%s\tPR-origin\n' "$number"
    return 0
  fi

  if number=$(extract_prefixed_number "$branch" "pr"); then
    printf 'pr\t%s\tPR-origin\n' "$number"
    return 0
  fi

  if number=$(extract_prefixed_number "$branch" "issue"); then
    printf 'issue\t%s\tissue-origin\n' "$number"
    return 0
  fi

  if number=$(extract_prefixed_number "$worktree_name" "issue"); then
    printf 'issue\t%s\tissue-origin\n' "$number"
    return 0
  fi

  printf 'misc\t-\tmiscellaneous\n'
}

github_repo_from_origin() {
  local repo_root="$1"
  local remote_url
  local repo=""

  remote_url=$(git -C "$repo_root" remote get-url origin 2>/dev/null || true)
  case "$remote_url" in
    git@github.com:*)
      repo="${remote_url#git@github.com:}"
      ;;
    https://github.com/*)
      repo="${remote_url#https://github.com/}"
      ;;
    ssh://git@github.com/*)
      repo="${remote_url#ssh://git@github.com/}"
      ;;
  esac

  repo="${repo%.git}"
  printf '%s\n' "$repo"
}

show_github_status() {
  local repo_root="$1"
  local origin_kind="$2"
  local origin_number="$3"
  local github_repo
  local output

  if [[ "$origin_kind" != "issue" && "$origin_kind" != "pr" ]]; then
    echo "GitHub: no issue or PR number detected"
    return 0
  fi

  if [[ "$origin_number" == "-" ]]; then
    echo "GitHub: no issue or PR number detected"
    return 0
  fi

  if ! command -v gh &>/dev/null; then
    echo "GitHub: gh command unavailable"
    return 0
  fi

  github_repo=$(github_repo_from_origin "$repo_root")
  if [[ -z "$github_repo" ]]; then
    echo "GitHub: origin is not a GitHub repository"
    return 0
  fi

  case "$origin_kind" in
    issue)
      if output=$(gh issue view "$origin_number" --repo "$github_repo" --json number,state,title,url --jq '"Issue #\(.number): \(.state)\n\(.title)\n\(.url)"' 2>/dev/null); then
        printf '%s\n' "$output"
      else
        echo "GitHub: issue status unavailable"
      fi
      ;;
    pr)
      if output=$(gh pr view "$origin_number" --repo "$github_repo" --json number,state,isDraft,mergeStateStatus,reviewDecision,title,url --jq '"PR #\(.number): \(.state)" + (if .isDraft then " draft" else "" end) + " merge=" + (.mergeStateStatus // "-") + " review=" + (.reviewDecision // "-") + "\n" + .title + "\n" + .url' 2>/dev/null); then
        printf '%s\n' "$output"
      else
        echo "GitHub: PR status unavailable"
      fi
      ;;
  esac
}

github_origin_status() {
  local repo_root="$1"
  local origin_kind="$2"
  local origin_number="$3"
  local github_repo
  local output

  if [[ "$origin_kind" != "issue" && "$origin_kind" != "pr" ]]; then
    echo "-"
    return 0
  fi

  if [[ "$origin_number" == "-" ]]; then
    echo "-"
    return 0
  fi

  if ! command -v gh &>/dev/null; then
    printf '%s:%s\n' "$origin_kind" "gh-unavailable"
    return 0
  fi

  github_repo=$(github_repo_from_origin "$repo_root")
  if [[ -z "$github_repo" ]]; then
    printf '%s:%s\n' "$origin_kind" "github-unavailable"
    return 0
  fi

  case "$origin_kind" in
    issue)
      if output=$(gh issue view "$origin_number" --repo "$github_repo" --json state --jq '.state' 2>/dev/null); then
        printf 'issue:%s\n' "$output"
      else
        echo "issue:unknown"
      fi
      ;;
    pr)
      if output=$(gh pr view "$origin_number" --repo "$github_repo" --json state,mergedAt --jq 'if .mergedAt != null then "MERGED" else .state end' 2>/dev/null); then
        printf 'pr:%s\n' "$output"
      else
        echo "pr:unknown"
      fi
      ;;
  esac
}

github_state_columns() {
  local repo_root="$1"
  local origin_kind="$2"
  local origin_number="$3"
  local github_state
  local issue_state="-"
  local pr_state="-"

  github_state=$(github_origin_status "$repo_root" "$origin_kind" "$origin_number")
  case "$github_state" in
    issue:*)
      issue_state="$github_state"
      ;;
    pr:*)
      pr_state="$github_state"
      ;;
  esac

  printf '%s\t%s\n' "$issue_state" "$pr_state"
}

show_branch_tracking() {
  local repo_root="$1"
  local branch="$2"
  local upstream
  local head
  local counts
  local ahead="-"
  local behind="-"

  if [[ -z "$branch" || "$branch" == "-" ]]; then
    echo "Branch: detached or unavailable"
    return 0
  fi

  head=$(git -C "$repo_root" rev-parse --short "refs/heads/${branch}" 2>/dev/null || true)
  upstream=$(git -C "$repo_root" for-each-ref --format='%(upstream:short)' "refs/heads/${branch}" 2>/dev/null || true)

  echo "Branch: ${branch}"
  if [[ -n "$head" ]]; then
    echo "HEAD: ${head}"
  else
    echo "HEAD: unavailable"
  fi

  if [[ -z "$upstream" ]]; then
    echo "Upstream: none"
    return 0
  fi

  echo "Upstream: ${upstream}"
  counts=$(git -C "$repo_root" rev-list --left-right --count "refs/heads/${branch}...${upstream}" 2>/dev/null || true)
  if [[ -n "$counts" ]]; then
    read -r ahead behind <<<"$counts"
  fi
  echo "Tracking: ahead=${ahead} behind=${behind}"
}

default_base_ref() {
  local repo_root="$1"
  local origin_head

  origin_head=$(git -C "$repo_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
  if [[ -n "$origin_head" ]]; then
    printf '%s\n' "$origin_head"
    return 0
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/remotes/origin/main; then
    printf '%s\n' "origin/main"
    return 0
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
    printf '%s\n' "main"
    return 0
  fi

  printf '%s\n' "HEAD"
}

base_branch_from_ref() {
  local base_ref="$1"

  case "$base_ref" in
    refs/remotes/origin/*)
      printf '%s\n' "${base_ref#refs/remotes/origin/}"
      ;;
    origin/*)
      printf '%s\n' "${base_ref#origin/}"
      ;;
    refs/heads/*)
      printf '%s\n' "${base_ref#refs/heads/}"
      ;;
    HEAD)
      printf '%s\n' ""
      ;;
    *)
      printf '%s\n' "$base_ref"
      ;;
  esac
}

branch_has_merged_github_pr() {
  local repo_root="$1"
  local branch="$2"
  local base_ref="$3"
  local origin_kind="${4:-misc}"
  local origin_number="${5:--}"
  local github_repo
  local base_branch
  local merged_count
  local merged_at

  if [[ "$origin_kind" == "pr" && "$origin_number" != "-" ]]; then
    github_repo=$(github_repo_from_origin "$repo_root")
    if [[ -n "$github_repo" ]] && command -v gh &>/dev/null; then
      merged_at=$(gh pr view "$origin_number" --repo "$github_repo" --json mergedAt --jq '.mergedAt // ""' 2>/dev/null || true)
      if [[ -n "$merged_at" ]]; then
        return 0
      fi
    fi
  fi

  if ! command -v gh &>/dev/null; then
    return 1
  fi

  github_repo=$(github_repo_from_origin "$repo_root")
  if [[ -z "$github_repo" ]]; then
    return 1
  fi

  base_branch=$(base_branch_from_ref "$base_ref")
  if [[ -n "$base_branch" ]]; then
    merged_count=$(gh pr list \
      --repo "$github_repo" \
      --state merged \
      --head "$branch" \
      --base "$base_branch" \
      --json number \
      --jq 'length' 2>/dev/null || true)
  else
    merged_count=$(gh pr list \
      --repo "$github_repo" \
      --state merged \
      --head "$branch" \
      --json number \
      --jq 'length' 2>/dev/null || true)
  fi

  case "$merged_count" in
    [1-9] | [1-9][0-9]*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

branch_merge_state() {
  local repo_root="$1"
  local branch="$2"
  local origin_kind="${3:-misc}"
  local origin_number="${4:--}"
  local base_ref

  if [[ -z "$branch" || "$branch" == "-" ]]; then
    echo "merge?"
    return 0
  fi

  if ! git -C "$repo_root" show-ref --verify --quiet "refs/heads/${branch}"; then
    echo "merge?"
    return 0
  fi

  base_ref=$(default_base_ref "$repo_root")
  if git -C "$repo_root" merge-base --is-ancestor "refs/heads/${branch}" "$base_ref" 2>/dev/null; then
    echo "merged"
  elif branch_has_merged_github_pr "$repo_root" "$branch" "$base_ref" "$origin_kind" "$origin_number"; then
    echo "merged"
  else
    echo "unmerged"
  fi
}

worktree_dirty_state() {
  local worktree_path="$1"
  local status_output

  if ! status_output=$(git -C "$worktree_path" --no-optional-locks status --porcelain 2>/dev/null); then
    echo "dirty?"
    return 0
  fi

  if [[ -n "$status_output" ]]; then
    echo "dirty"
  else
    echo "clean"
  fi
}

branch_upstream_status() {
  local repo_root="$1"
  local branch="$2"
  local upstream
  local counts
  local ahead="-"
  local behind="-"
  local upstream_state

  if [[ -z "$branch" || "$branch" == "-" ]]; then
    printf '%s\t%s\t%s\t%s\n' "-" "-" "-" "-"
    return 0
  fi

  upstream=$(git -C "$repo_root" for-each-ref --format='%(upstream:short)' "refs/heads/${branch}" 2>/dev/null || true)
  if [[ -z "$upstream" ]]; then
    printf '%s\t%s\t%s\t%s\n' "-" "none" "-" "-"
    return 0
  fi

  if ! git -C "$repo_root" rev-parse --verify --quiet "${upstream}^{commit}" >/dev/null; then
    printf '%s\t%s\t%s\t%s\n' "$upstream" "deleted" "-" "-"
    return 0
  fi

  upstream_state="exists"
  counts=$(git -C "$repo_root" rev-list --left-right --count "refs/heads/${branch}...${upstream}" 2>/dev/null || true)
  if [[ -n "$counts" ]]; then
    read -r ahead behind <<<"$counts"
  fi

  printf '%s\t%s\t%s\t%s\n' "$upstream" "$upstream_state" "$ahead" "$behind"
}

format_upstream_status() {
  local upstream_state="$1"
  local ahead="$2"
  local behind="$3"

  case "$upstream_state" in
    exists)
      printf 'upstream:exists(+%s/-%s)\n' "$ahead" "$behind"
      ;;
    none)
      printf 'upstream:none\n'
      ;;
    deleted)
      printf 'upstream:deleted\n'
      ;;
    *)
      printf 'upstream:-\n'
      ;;
  esac
}

worktree_lock_state() {
  local repo_root="$1"
  local worktree_path="$2"

  git -C "$repo_root" worktree list --porcelain | awk \
    -v target="$worktree_path" '
    function flush() {
      if (!found && path == target) {
        print lock_state
        found = 1
      }
    }

    /^worktree / {
      flush()
      path = substr($0, 10)
      lock_state = "unlocked"
      next
    }

    /^locked/ {
      if (path == target) {
        lock_state = "locked"
      }
      next
    }

    END {
      flush()
      if (!found) {
        print "missing"
      }
    }
  '
}

list_managed_worktrees() {
  local repo_root="$1"
  local managed_root="$2"

  git -C "$repo_root" worktree list --porcelain | awk \
    -v repo_root="$repo_root" \
    -v managed_root="$managed_root" '
    function flush() {
      if (path != "" && path != repo_root && index(path, managed_root "/") == 1) {
        if (branch == "") {
          branch = "-"
        }
        print branch "\t" lock_state "\t" path
      }
    }

    /^worktree / {
      flush()
      path = substr($0, 10)
      branch = ""
      lock_state = "unlocked"
      next
    }

    /^branch / {
      ref = substr($0, 8)
      if (index(ref, "refs/heads/") == 1) {
        branch = substr(ref, 12)
      }
      next
    }

    /^detached$/ {
      branch = "-"
      next
    }

    /^locked/ {
      lock_state = "locked"
      next
    }

    END {
      flush()
    }
  '
}

preview_worktree() {
  local issue_state="$1"
  local pr_state="$2"
  local upstream_status="$3"
  local branch="$4"
  local upstream_remote="$5"
  local worktree_path="$6"

  echo "Status"
  echo "  Issue:           ${issue_state}"
  echo "  PR:              ${pr_state}"
  echo "  Upstream state:  ${upstream_status}"
  echo ""
  echo "Target"
  echo "  Branch:          ${branch}"
  echo "  Upstream branch: ${upstream_remote}"
  echo "  Path:            ${worktree_path}"
}

if [[ "${1:-}" == "__preview" ]]; then
  shift
  if [[ $# -ne 6 ]]; then
    echo "preview unavailable: invalid arguments" >&2
    exit 0
  fi
  preview_worktree "$@"
  exit 0
fi

if [[ $# -gt 0 ]]; then
  case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
fi

if [[ ! -t 0 ]]; then
  echo "Error: worktree-remove requires an interactive terminal." >&2
  exit 1
fi

require_command git
require_command fzf

inventory_file=$(mktemp)
trap 'rm -f "$inventory_file"' EXIT HUP INT TERM

if ! current_root=$(git rev-parse --show-toplevel 2>/dev/null); then
  echo "Error: worktree-remove must be run inside a git repository." >&2
  exit 1
fi

case "$current_root" in
  *"/.worktrees/"*)
    repo_root="${current_root%%/.worktrees/*}"
    ;;
  *)
    repo_root="$current_root"
    ;;
esac

managed_root="${repo_root}/.worktrees"

if ! raw_inventory=$(list_managed_worktrees "$repo_root" "$managed_root"); then
  echo "Error: failed to list worktrees for ${repo_root}." >&2
  exit 1
fi

while IFS=$'\t' read -r branch lock_state worktree_path; do
  if [[ -z "$worktree_path" ]]; then
    continue
  fi

  origin_record=$(classify_worktree "$branch" "$worktree_path")
  IFS=$'\t' read -r origin_kind origin_number _ <<<"$origin_record"
  github_record=$(github_state_columns "$repo_root" "$origin_kind" "$origin_number")
  IFS=$'\t' read -r issue_state pr_state <<<"$github_record"
  upstream_record=$(branch_upstream_status "$repo_root" "$branch")
  IFS=$'\t' read -r upstream_remote upstream_state upstream_ahead upstream_behind <<<"$upstream_record"
  upstream_status=$(format_upstream_status "$upstream_state" "$upstream_ahead" "$upstream_behind")

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$issue_state" \
    "$pr_state" \
    "$upstream_status" \
    "$branch" \
    "$worktree_path" \
    "$lock_state" \
    "$repo_root" \
    "$managed_root" \
    "$origin_kind" \
    "$origin_number" \
    "$upstream_remote" \
    "$upstream_state" \
    "$upstream_ahead" \
    "$upstream_behind" >>"$inventory_file"
done <<<"$raw_inventory"

inventory=$(cat "$inventory_file")

if [[ -z "$inventory" ]]; then
  echo "No removable managed worktrees found under ${managed_root}."
  exit 0
fi

script_path="$0"
case "$script_path" in
  */*) ;;
  *)
    script_path=$(command -v "$script_path" 2>/dev/null || printf '%s\n' "$script_path")
    ;;
esac
preview_command=$(printf '%q __preview {1} {2} {3} {4} {11} {5}' "$script_path")

if ! selection="$(
  printf '%s\n' "$inventory" |
    fzf \
      --delimiter=$'\t' \
      --with-nth=1,2,3,4,11,5 \
      --prompt='worktree-remove> ' \
      --header='Select a worktree to remove. Columns: issue PR upstream branch upstream-branch path' \
      --preview="$preview_command" \
      --preview-window='down,60%'
)"; then
  echo "Cancelled."
  exit 0
fi

IFS=$'\t' read -r issue_state pr_state upstream_status branch worktree_path lock_state repo_root managed_root origin_kind origin_number upstream_remote upstream_state upstream_ahead upstream_behind <<<"$selection"

if [[ -z "$branch" || -z "$worktree_path" || -z "$repo_root" || -z "$managed_root" ]]; then
  echo "Error: could not parse selected worktree." >&2
  exit 1
fi

if [[ "$worktree_path" == "$repo_root" ]]; then
  echo "Error: refusing to remove the primary worktree: ${repo_root}" >&2
  exit 1
fi

if [[ "$worktree_path" != "$managed_root/"* ]]; then
  echo "Error: refusing to remove path outside managed root: ${worktree_path}" >&2
  exit 1
fi

if [[ ! -d "$worktree_path" ]]; then
  echo "Error: selected worktree directory does not exist: ${worktree_path}" >&2
  exit 1
fi

if [[ ! -f "$worktree_path/.git" ]]; then
  echo "Error: refusing to remove a path that is not a linked worktree: ${worktree_path}" >&2
  exit 1
fi

dirty_state=$(worktree_dirty_state "$worktree_path")
lock_state=$(worktree_lock_state "$repo_root" "$worktree_path")
merge_state=$(branch_merge_state "$repo_root" "$branch" "$origin_kind" "$origin_number")
github_record=$(github_state_columns "$repo_root" "$origin_kind" "$origin_number")
IFS=$'\t' read -r issue_state pr_state <<<"$github_record"
upstream_record=$(branch_upstream_status "$repo_root" "$branch")
IFS=$'\t' read -r upstream_remote upstream_state upstream_ahead upstream_behind <<<"$upstream_record"
upstream_status=$(format_upstream_status "$upstream_state" "$upstream_ahead" "$upstream_behind")

if [[ "$dirty_state" != "clean" ]]; then
  echo "Error: refusing to remove a dirty worktree: ${worktree_path}" >&2
  exit 1
fi

if [[ "$lock_state" == "missing" ]]; then
  echo "Error: selected worktree is no longer registered: ${worktree_path}" >&2
  exit 1
fi

if [[ "$lock_state" != "unlocked" ]]; then
  echo "Error: refusing to remove a locked worktree: ${worktree_path}" >&2
  exit 1
fi

if [[ "$branch" != "-" && "$merge_state" != "merged" ]]; then
  echo "Error: refusing to remove an unmerged branch worktree: ${branch}" >&2
  exit 1
fi

echo "Selected worktree:"
echo "  Issue:           ${issue_state}"
echo "  PR:              ${pr_state}"
echo "  Upstream state:  ${upstream_status}"
echo "  Branch:          ${branch}"
echo "  Upstream branch: ${upstream_remote}"
echo "  Path:            ${worktree_path}"
echo ""
echo "This will remove the linked worktree and its local branch with git worktree."
printf 'Type yes to continue: '
read -r answer

if [[ "$answer" != "yes" ]]; then
  echo "Cancelled."
  exit 0
fi

cd "$repo_root"
git worktree remove "$worktree_path"
if [[ "$branch" != "-" ]]; then
  git branch -D "$branch"
fi

if command -v zoxide &>/dev/null; then
  zoxide remove "$worktree_path" >/dev/null 2>&1 || true
fi

echo "Removed: ${branch} (${worktree_path})"
