#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Create a git worktree for the specified GitHub issue(s).
# Uses Claude to generate a descriptive branch name from the issue content.
# Falls back to title-based naming if Claude is not available.
#
# Usage:
#   issue-worktree-create [--allow-direnv|--no-allow-direnv] <issue_number> [issue_number2 ...]
#
# Dependencies:
#   - gh (GitHub CLI)
#   - jq
#   - claude (Anthropic CLI, optional)
#   - repo-setup (optional)
#   - direnv (required by repo-setup when allowing generated or copied .envrc)

# Check required dependencies
for cmd in gh jq git; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd command not found. Please install it." >&2
    exit 1
  fi
done

direnv_mode="default"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --allow-direnv)
      direnv_mode="allow"
      shift
      ;;
    --no-allow-direnv)
      direnv_mode="deny"
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Error: unknown option: $1" >&2
      echo "Usage: $0 [--allow-direnv|--no-allow-direnv] <issue_number> [issue_number2 ...]" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

# Check arguments
if [[ $# -eq 0 ]]; then
  echo "Usage: $0 [--allow-direnv|--no-allow-direnv] <issue_number> [issue_number2 ...]" >&2
  echo "Example: $0 123" >&2
  echo "Example: $0 --no-allow-direnv 123" >&2
  echo "Example: $0 123 456 789" >&2
  exit 1
fi

# Get repository root
repo_root=$(git rev-parse --show-toplevel)

find_worktree_for_branch() {
  local branch=$1
  local target_ref="refs/heads/${branch}"

  git worktree list --porcelain | awk -v target_ref="$target_ref" '
    /^worktree / {
      path = substr($0, 10)
    }
    /^branch / {
      if (substr($0, 8) == target_ref) {
        print path
        found = 1
      }
    }
    END {
      exit found ? 0 : 1
    }
  '
}

ensure_remote_tracking_branch() {
  local branch=$1
  local upstream="origin/${branch}"
  local actual_upstream

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    git branch --set-upstream-to="${upstream}" "${branch}"
  else
    git branch --track "${branch}" "${upstream}"
  fi

  actual_upstream=$(branch_upstream "${branch}")
  if [[ $actual_upstream != "$upstream" ]]; then
    echo "Error: local issue branch upstream is '${actual_upstream}', expected '${upstream}'." >&2
    return 1
  fi
}

same_checkout_path() {
  local left=$1
  local right=$2
  local left_physical
  local right_physical

  left_physical=$(cd "$left" && pwd -P)
  right_physical=$(cd "$right" && pwd -P)
  [[ $left_physical == "$right_physical" ]]
}

branch_upstream() {
  local branch=$1

  git for-each-ref --format='%(upstream:short)' "refs/heads/${branch}" 2>/dev/null || true
}

same_name_remote_exists() {
  local branch=$1

  git show-ref --verify --quiet "refs/remotes/origin/${branch}"
}

ensure_issue_branch_upstream_invariant() {
  local branch=$1
  local upstream
  local expected_upstream="origin/${branch}"

  upstream=$(branch_upstream "${branch}")

  if [[ -z $upstream ]]; then
    echo "* Branch upstream: none"
    return 0
  fi

  if [[ $upstream == "$expected_upstream" ]] && same_name_remote_exists "${branch}"; then
    echo "* Branch upstream: ${upstream}"
    return 0
  fi

  if [[ $upstream == "$expected_upstream" ]]; then
    echo "* Clearing stale same-name upstream without remote: ${upstream}"
  else
    echo "* Clearing unsafe issue branch upstream: ${upstream}"
  fi

  git branch --unset-upstream "${branch}"
  echo "* Branch upstream: none"
}

run_repo_setup_for_worktree() {
  local worktree_path=$1
  local allow_envrc=$2
  local allow_message=$3
  local allow_generated_envrc=$4

  if ! command -v repo-setup &>/dev/null; then
    return 0
  fi

  echo "-> Running repo-setup..."
  (
    cd "$worktree_path"
    if [[ ${allow_envrc} == "true" ]]; then
      if [[ -n $allow_message ]]; then
        echo "* ${allow_message}"
      fi
      repo-setup --allow-direnv
    elif [[ ${allow_generated_envrc} == "false" ]]; then
      repo-setup --no-allow-generated-envrc
    else
      repo-setup
    fi
  )
}

# Fetch remote and update main branch when it is the invoking branch.
echo "-> Fetching remote..."
git fetch origin
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [[ "$current_branch" == "main" ]]; then
  git pull --ff-only origin main
else
  echo "* Keeping local main unchanged while ${current_branch} is checked out"
fi
echo ""

# Process each issue number
had_failure="false"
for issue_number in "$@"; do
  # Validate issue number
  if [[ ! $issue_number =~ ^[0-9]+$ ]]; then
    echo "Warning: '$issue_number' is not a valid issue number. Skipping." >&2
    echo ""
    had_failure="true"
    continue
  fi

  echo "=== Processing Issue #${issue_number} ==="

  # Fetch issue information
  echo "-> Fetching issue info..."
  if ! issue_json=$(gh issue view "${issue_number}" --json title,body,comments 2>&1); then
    echo "Error: Failed to fetch Issue #${issue_number}. Skipping." >&2
    echo "${issue_json}" >&2
    echo ""
    had_failure="true"
    continue
  fi

  issue_title=$(jq -r '.title // empty' <<<"$issue_json")
  issue_body=$(jq -r '.body // empty' <<<"$issue_json")
  issue_comments=$(jq -r '.comments[]?.body // empty' <<<"$issue_json" | head -c 2000)

  if [[ -z $issue_title ]]; then
    echo "Error: Issue #${issue_number} has no title. Skipping." >&2
    echo ""
    had_failure="true"
    continue
  fi

  # Check for existing remote branch with issue number prefix
  echo "-> Checking for existing remote branch..."
  existing_branch=""
  if git show-ref --verify --quiet "refs/remotes/origin/issue-${issue_number}"; then
    existing_branch="issue-${issue_number}"
  else
    existing_branch=$(git branch -r --list "origin/issue-${issue_number}-*" | head -n 1 | sed 's|^[[:space:]]*origin/||')
  fi

  if [[ -n $existing_branch ]]; then
    echo "  Found existing remote branch: ${existing_branch}"
    branch_name="$existing_branch"
  else
    # Generate branch name
    echo "-> Generating branch name..."
    branch_slug=""

    # Try Claude first if available
    if command -v claude &>/dev/null; then
      prompt="Generate a short English slug (kebab-case) for a Git branch name from the following issue.
- Maximum 5 words
- Lowercase alphabet, number and hyphens only
- Remove special characters
- Start with a verb if possible

Return ONLY the slug (no explanation).

---
Issue title: ${issue_title}
---
Issue body:
${issue_body}
---
Issue comments:
${issue_comments}
---"

      branch_slug=$(claude --print \
        --system-prompt "Output ONLY the raw slug. No decorations, insights, or explanations." \
        "$prompt" 2>/dev/null \
        | tail -n 1 \
        | tr '[:upper:]' '[:lower:]' \
        | tr -cd 'a-z0-9-' \
        | sed 's/--*/-/g; s/^-//; s/-$//' \
        | cut -c 1-50) || true
    fi

    # Fallback: use issue number only
    if [[ -z $branch_slug ]]; then
      echo "  (Using fallback: issue number only)"
      branch_name="issue-${issue_number}"
    else
      branch_name="issue-${issue_number}-${branch_slug}"
    fi
  fi
  echo "* Branch name: ${branch_name}"

  worktree_name="${branch_name//\//-}"
  desired_worktree_path="${repo_root}/.worktrees/${worktree_name}"
  existing_worktree_path=""
  if existing_worktree_path=$(find_worktree_for_branch "${branch_name}" 2>/dev/null); then
    :
  else
    existing_worktree_path=""
  fi

  if git ls-remote --exit-code --heads origin "${branch_name}" >/dev/null 2>&1; then
    branch_origin="remote"
    if ! git fetch origin "+refs/heads/${branch_name}:refs/remotes/origin/${branch_name}"; then
      echo "Error: Could not fetch origin/${branch_name}. Skipping." >&2
      echo ""
      had_failure="true"
      continue
    fi
    if ! ensure_remote_tracking_branch "${branch_name}"; then
      echo "Error: Could not connect local branch to origin/${branch_name}. Skipping." >&2
      echo ""
      had_failure="true"
      continue
    fi
  elif git show-ref --verify --quiet "refs/heads/${branch_name}"; then
    branch_origin="local"
  else
    branch_origin="new"
  fi

  if [[ -n $existing_worktree_path ]]; then
    worktree_path=$existing_worktree_path
  else
    mkdir -p "${repo_root}/.worktrees"
    if [[ -e $desired_worktree_path ]]; then
      echo "Error: desired issue worktree path already exists: ${desired_worktree_path}" >&2
      echo ""
      had_failure="true"
      continue
    fi

    case "${branch_origin}" in
      remote | local)
        if ! git worktree add "${desired_worktree_path}" "${branch_name}"; then
          echo "Error: Could not prepare worktree for '${branch_name}' at '${desired_worktree_path}'." >&2
          echo ""
          had_failure="true"
          continue
        fi
        ;;
      new)
        if ! git worktree add -b "${branch_name}" "${desired_worktree_path}" "${current_branch}"; then
          echo "Error: Could not create worktree for '${branch_name}' at '${desired_worktree_path}'." >&2
          echo ""
          had_failure="true"
          continue
        fi
        ;;
    esac

    worktree_path=$desired_worktree_path
  fi

  if ! ensure_issue_branch_upstream_invariant "${branch_name}"; then
    echo "Error: Could not verify issue branch upstream safety for '${branch_name}'. Skipping." >&2
    echo ""
    had_failure="true"
    continue
  fi

  if [[ -n $existing_worktree_path ]]; then
    echo "* Worktree already exists: ${worktree_path}"
    echo "* Branch: ${branch_name}"
    if [[ ${direnv_mode} == "allow" ]]; then
      run_repo_setup_for_worktree "${worktree_path}" "true" "" "true"
    elif [[ ${direnv_mode} != "deny" ]] &&
      ! same_checkout_path "${repo_root}" "${worktree_path}" &&
      [[ -f "${repo_root}/.envrc" ]] &&
      [[ -f "${worktree_path}/.envrc" ]] &&
      cmp -s "${repo_root}/.envrc" "${worktree_path}/.envrc"; then
      run_repo_setup_for_worktree \
        "${worktree_path}" \
        "true" \
        "Allowing existing copied source .envrc for issue worktree" \
        "true"
    elif [[ -f "${worktree_path}/.envrc" ]]; then
      if [[ ${direnv_mode} == "deny" ]]; then
        echo "* Existing .envrc not allowed by request; run repo-setup --allow-direnv after review"
      elif same_checkout_path "${repo_root}" "${worktree_path}"; then
        echo "* Existing .envrc from this issue worktree not allowed by default; run repo-setup --allow-direnv after review"
      else
        echo "* Existing .envrc differs from source .envrc; run repo-setup --allow-direnv after review"
      fi
    fi
  else
    echo "* Created worktree: ${worktree_path}"

    case "${branch_origin}" in
      remote)
        echo "* Using remote branch: ${branch_name}"
        ;;
      local)
        echo "* Using existing local branch: ${branch_name}"
        ;;
      new)
        echo "* Created local branch: ${branch_name} (from ${current_branch})"
        ;;
    esac

    worktree_had_envrc="false"
    if [[ -f "${worktree_path}/.envrc" ]]; then
      worktree_had_envrc="true"
    fi

    copied_envrc="false"
    if [[ -f "${repo_root}/.envrc" ]]; then
      if [[ ${worktree_had_envrc} == "true" ]]; then
        echo "* Existing .envrc from issue branch left unchanged"
      else
        cp "${repo_root}/.envrc" "${worktree_path}/.envrc"
        copied_envrc="true"
        echo "* Copied .envrc to worktree"
      fi
    fi

    allow_envrc="false"
    allow_generated_envrc="true"
    allow_message=""
    if [[ ${direnv_mode} == "allow" ]]; then
      allow_envrc="true"
    elif [[ ${direnv_mode} == "deny" ]]; then
      allow_generated_envrc="false"
      if [[ ${copied_envrc} == "true" ]]; then
        echo "* Copied .envrc not allowed by request; run repo-setup --allow-direnv after review"
      elif [[ ${worktree_had_envrc} == "true" ]]; then
        echo "* Existing .envrc from issue branch not allowed by request; run repo-setup --allow-direnv after review"
      elif [[ -f "${worktree_path}/flake.nix" ]]; then
        echo "* Generated .envrc not allowed by request; run repo-setup --allow-direnv after review"
      fi
    elif [[ ${copied_envrc} == "true" ]]; then
      allow_envrc="true"
      allow_message="Allowing copied source .envrc for issue worktree"
    elif [[ ${worktree_had_envrc} == "true" ]]; then
      allow_generated_envrc="false"
      echo "* Existing .envrc from issue branch not allowed by default; run repo-setup --allow-direnv after review"
    fi

    run_repo_setup_for_worktree "${worktree_path}" "${allow_envrc}" "${allow_message}" "${allow_generated_envrc}"
  fi

  if command -v zoxide &>/dev/null; then
    zoxide add "$worktree_path"
    echo "* Added worktree to zoxide database"
  fi

  echo ""
done

if [[ $had_failure == "true" ]]; then
  echo "Error: Some issue worktrees could not be prepared." >&2
  echo ""
  exit 1
fi

echo "* All issue worktrees are ready."
echo ""
