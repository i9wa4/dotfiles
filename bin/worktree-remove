#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Remove linked git worktree(s) by managed branch or path.
# Safely removes only worktrees (not regular repositories).
# Dirty worktrees are refused by default; this command does not force dirty
# deletion.
# Managed branch names resolve through the current repo worktree list, and the
# actual cleanup runs through `vde-worktree del` so the repo wrapper follows
# the current managed backend.
#
# Usage:
#   worktree-remove <branch-or-path> [branch-or-path2 ...]
#
# Preferred target formats:
#   - Managed issue branch: issue-123-fix-thing
#   - Managed review branch: pr-456-review-branch
#   - Repo-local path: .worktrees/issue-123-fix-thing
#   - Absolute path: /path/to/repo/.worktrees/issue-123-fix-thing
#
# Fallback target format:
#   - ghq-relative path: github.com/org/project/.worktrees/issue-123-fix-thing
#     (optional, if it already exists under `ghq root`)

# Check required dependencies
if ! command -v git &>/dev/null; then
  echo "Error: git command not found. Please install it." >&2
  exit 1
fi

if ! command -v vde-worktree &>/dev/null; then
  echo "Error: vde-worktree command not found. Please install it." >&2
  exit 1
fi

# Check arguments
if [[ $# -eq 0 ]]; then
  echo "Usage: $0 <branch-or-path> [branch-or-path2 ...]" >&2
  echo "" >&2
  echo "Default behavior:" >&2
  echo "  Dirty worktrees are refused; this command keeps issue/PR cleanup aligned" >&2
  echo "  with the managed backend and does not force dirty deletion." >&2
  echo "" >&2
  echo "Preferred targets:" >&2
  echo "  issue branch:  issue-123-fix-thing" >&2
  echo "  pr branch:     pr-456-review-branch" >&2
  echo "  repo path:     .worktrees/issue-123-fix-thing" >&2
  echo "  absolute path: /path/to/repo/.worktrees/issue-123-fix-thing" >&2
  echo "" >&2
  echo "Fallback target:" >&2
  echo "  ghq-relative path: github.com/org/project/.worktrees/issue-123-fix-thing" >&2
  exit 1
fi

resolve_branch_path() {
  local input="$1"

  git worktree list --porcelain 2>/dev/null | awk -v wanted="$input" '
    $1 == "worktree" {
      path = substr($0, 10)
      next
    }
    $1 == "branch" && $2 ~ /^refs\/heads\// {
      branch = substr($2, 12)
      if (branch == wanted) {
        print path
        exit
      }
    }
  '
}

resolve_existing_path() {
  local input="$1"
  local ghq_candidate

  if [[ "$input" = /* ]] && [[ -d "$input" ]]; then
    cd "$input" 2>/dev/null && pwd -P
    return 0
  fi

  if [[ -d "$input" ]]; then
    cd "$input" 2>/dev/null && pwd -P
    return 0
  fi

  if command -v ghq &>/dev/null; then
    ghq_candidate="$(ghq root)/${input}"
    if [[ -d "$ghq_candidate" ]]; then
      cd "$ghq_candidate" 2>/dev/null && pwd -P
      return 0
    fi
  fi

  return 1
}

main_repo_path() {
  local worktree_path="$1"
  local common_dir

  common_dir="$(git -C "$worktree_path" rev-parse --git-common-dir)"
  if [[ "$common_dir" != /* ]]; then
    common_dir="${worktree_path}/${common_dir}"
  fi

  cd "$(dirname "$common_dir")" 2>/dev/null && pwd -P
}

worktree_branch_name() {
  local worktree_path="$1"

  git -C "$worktree_path" branch --show-current 2>/dev/null
}

run_managed_delete() {
  local repo_root="$1"
  local branch="$2"

  if [[ -t 1 ]]; then
    (
      cd "$repo_root"
      vde-worktree init >/dev/null
      vde-worktree del "$branch" --force-unmerged --allow-unpushed
    )
  else
    (
      cd "$repo_root"
      vde-worktree init >/dev/null
      vde-worktree del "$branch" --force-unmerged --allow-unpushed --allow-unsafe
    )
  fi
}

for target in "$@"; do
  repo_path=""
  target_branch=""
  branch_path="$(resolve_branch_path "$target")"

  echo "Processing: ${target}"

  if [[ -n "$branch_path" ]]; then
    repo_path="$branch_path"
    target_branch="$target"
    echo "  * Resolved managed branch to path: ${repo_path}"
  elif repo_path="$(resolve_existing_path "$target")"; then
    target_branch="$(worktree_branch_name "$repo_path")"
    if [[ -n "$target_branch" ]]; then
      echo "  * Resolved linked worktree path to branch: ${target_branch}"
    fi
  else
    echo "  Warning: Worktree target not found: ${target}" >&2
    continue
  fi

  if [[ ! -d $repo_path ]]; then
    echo "  Warning: Directory does not exist: ${repo_path}" >&2
    continue
  fi

  if [[ -f "${repo_path}/.git" ]]; then
    if [[ -z "$target_branch" ]]; then
      echo "  Warning: Could not resolve a branch-backed managed worktree: ${repo_path}" >&2
      echo ""
      continue
    fi

    echo "  -> Removing linked worktree with vde-worktree del..."

    main_repo="$(main_repo_path "$repo_path")"
    run_managed_delete "${main_repo}" "${target_branch}"
    if command -v zoxide &>/dev/null; then
      if zoxide remove "${repo_path}" >/dev/null 2>&1; then
        echo "  * Removed from zoxide database"
      else
        echo "  * No zoxide database entry to remove"
      fi
    fi
    echo "  * Removed: ${target_branch} (${repo_path})"
  else
    echo "  Warning: Not a linked worktree (regular repository): ${repo_path}" >&2
  fi

  echo ""
done

echo "* Done."
