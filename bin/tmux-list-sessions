#!/usr/bin/env bash

# Display tmux session list with numbered indices for the status line.
# Supports click-to-switch via tmux range and Alt+N switching.
#
# Usage:
#   tmux-list-sessions              Render session list for status-left
#   tmux-list-sessions switch <N>   Switch to session at 1-based index N
#
# Output format (render):
#   [1 current] 2 other 3 other
#   Current session shown in reverse; all sessions clickable via range.

TMUX_BIN="${TMUX_BIN:-tmux}"

list_sessions() {
  "${TMUX_BIN}" list-sessions -F $'#{session_id}\t#{session_name}'
}

current_session() {
  "${TMUX_BIN}" display-message -p '#{session_name}'
}

render_sessions() {
  local current index session_id session_name label output
  current="$(current_session)"
  output=""
  index=1

  while IFS=$'\t' read -r session_id session_name; do
    if [[ -z "${session_id}" || -z "${session_name}" ]]; then
      continue
    fi

    if (( index <= 9 )); then
      label="${index} ${session_name}"
    else
      label="${session_name}"
    fi

    output+="#[range=session|${session_id}]"
    if [[ "${session_name}" == "${current}" ]]; then
      output+="#[reverse,bold] ${label} #[default]"
    else
      output+=" ${label} "
    fi
    output+="#[norange]"

    index=$((index + 1))
  done < <(list_sessions)

  printf '%s\n' "${output}"
}

resolve_session_name() {
  local target_index="$1"
  local current_index=1
  local session_id session_name

  while IFS=$'\t' read -r session_id session_name; do
    if [[ -z "${session_name}" ]]; then
      continue
    fi
    if (( current_index == target_index )); then
      printf '%s\n' "${session_name}"
      return 0
    fi
    current_index=$((current_index + 1))
  done < <(list_sessions)

  return 1
}

switch_session() {
  local target_index="$1"
  local target_name

  if [[ ! "${target_index}" =~ ^[1-9][0-9]*$ ]]; then
    printf 'tmux-list-sessions: index must be a positive integer: %s\n' "${target_index}" >&2
    return 2
  fi

  target_name="$(resolve_session_name "${target_index}")" || {
    printf 'tmux-list-sessions: session not found at index %s\n' "${target_index}" >&2
    return 1
  }

  exec "${TMUX_BIN}" switch-client -t "${target_name}"
}

case "${1:-render}" in
  render)
    render_sessions
    ;;
  switch)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: tmux-list-sessions switch <index>" >&2
      exit 2
    fi
    switch_session "$2"
    ;;
  -h|--help|help)
    echo "Usage: tmux-list-sessions [render|switch <N>]"
    ;;
  *)
    echo "Usage: tmux-list-sessions [render|switch <N>]" >&2
    exit 2
    ;;
esac
