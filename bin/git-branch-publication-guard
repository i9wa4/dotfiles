#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Git pre-push guard for branch publication safety.
# stdin lines follow githooks(5): local-ref local-oid remote-ref remote-oid.

zero_oid="0000000000000000000000000000000000000000"
current_branch="$(git branch --show-current 2>/dev/null || true)"
had_error="false"

is_protected_branch() {
  case "$1" in
    main | dev)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_local_branch() {
  local local_ref=$1

  case "${local_ref}" in
    refs/heads/*)
      printf '%s\n' "${local_ref#refs/heads/}"
      ;;
    HEAD)
      if [[ -n ${current_branch} ]]; then
        printf '%s\n' "${current_branch}"
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

while read -r local_ref local_oid remote_ref remote_oid; do
  if [[ -z ${local_ref:-} || -z ${local_oid:-} || -z ${remote_ref:-} || -z ${remote_oid:-} ]]; then
    echo "git-branch-publication-guard: malformed pre-push input; refusing to continue" >&2
    had_error="true"
    continue
  fi

  # Delete and tag handling belongs to separate policy. This guard only covers
  # non-delete branch publications.
  if [[ ${local_ref} == "(delete)" || ${local_oid} == "${zero_oid}" ]]; then
    continue
  fi

  if [[ ${remote_ref} != refs/heads/* ]]; then
    continue
  fi

  remote_branch="${remote_ref#refs/heads/}"

  if is_protected_branch "${remote_branch}"; then
    echo "git-branch-publication-guard: refusing to publish to protected branch '${remote_branch}'" >&2
    had_error="true"
    continue
  fi

  if ! local_branch="$(resolve_local_branch "${local_ref}")" || [[ -z ${local_branch} ]]; then
    echo "git-branch-publication-guard: refusing to publish '${local_ref}' to '${remote_branch}' because the source does not identify a local branch" >&2
    had_error="true"
    continue
  fi

  if [[ ${local_branch} != "${remote_branch}" ]]; then
    echo "git-branch-publication-guard: refusing branch-name mismatch: local '${local_branch}' -> remote '${remote_branch}'" >&2
    had_error="true"
  fi
done

if [[ ${had_error} == "true" ]]; then
  exit 1
fi
