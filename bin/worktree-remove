#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Select and remove one managed worktree from the current repository.
# The destructive removal is delegated to `vde-worktree del`, which keeps the
# same dirty, locked, unmerged, and unpushed safety checks as the backend.

usage() {
  cat <<'EOF'
Usage:
  worktree-remove

Select a managed worktree with fzf, confirm by typing "yes", then remove it
with vde-worktree del.

Options:
  -h, --help  Show this help.
EOF
}

require_command() {
  local command_name="$1"

  if ! command -v "$command_name" &>/dev/null; then
    echo "Error: ${command_name} command not found. Please install it." >&2
    exit 1
  fi
}

main_repo_path() {
  local worktree_path="$1"
  local common_dir

  common_dir="$(git -C "$worktree_path" rev-parse --git-common-dir)"
  if [[ "$common_dir" != /* ]]; then
    common_dir="${worktree_path}/${common_dir}"
  fi

  cd "$(dirname "$common_dir")" 2>/dev/null && pwd -P
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
fi

if [[ ! -t 0 ]]; then
  echo "Error: worktree-remove requires an interactive terminal." >&2
  exit 1
fi

require_command git
require_command jq
require_command fzf
require_command vde-worktree

current_root="$(git rev-parse --show-toplevel)"
repo_root="$(main_repo_path "$current_root")"

list_json="$(
  cd "$repo_root"
  vde-worktree list --json
)"

managed_root="$(printf '%s' "$list_json" | jq -r '.managedWorktreeRoot // empty')"
if [[ -z "$managed_root" ]]; then
  echo "Error: vde-worktree did not report a managed worktree root." >&2
  exit 1
fi

inventory="$(
  printf '%s' "$list_json" |
    jq -r '
      (.repoRoot // "") as $repoRoot
      | (.managedWorktreeRoot // "") as $managedRoot
      | .worktrees[]?
      | select((.branch // "") != "")
      | select((.path // "") != $repoRoot)
      | select($managedRoot != "" and ((.path // "") | startswith($managedRoot + "/")))
      | [
          (.branch // ""),
          (.path // ""),
          (if .dirty == true then "dirty" else "clean" end),
          (if .merged.overall == true then "merged" elif .merged.overall == false then "unmerged" else "merge?" end),
          (if .locked.value == true then "locked" else "unlocked" end),
          (.pr.status // "-"),
          ((.upstream.ahead // "-") | tostring),
          ((.upstream.behind // "-") | tostring)
        ]
      | @tsv
    '
)"

if [[ -z "$inventory" ]]; then
  echo "No removable managed worktrees found for ${repo_root}."
  exit 0
fi

if ! selection="$(
  printf '%s\n' "$inventory" |
    fzf \
      --delimiter=$'\t' \
      --with-nth=1,3,4,5,6,7,8,2 \
      --prompt='worktree-remove> ' \
      --header='Select a worktree to remove. Columns: branch state merge lock PR ahead behind path' \
      --preview='git -C {2} --no-optional-locks status --short 2>/dev/null; printf "\n"; git -C {2} log -n 8 --oneline 2>/dev/null' \
      --preview-window='down,60%'
)"; then
  echo "Cancelled."
  exit 0
fi

IFS=$'\t' read -r branch worktree_path dirty_state merge_state lock_state pr_status upstream_ahead upstream_behind <<<"$selection"

if [[ -z "$branch" || -z "$worktree_path" ]]; then
  echo "Error: could not parse selected worktree." >&2
  exit 1
fi

if [[ "$worktree_path" == "$repo_root" ]]; then
  echo "Error: refusing to remove the primary worktree: ${repo_root}" >&2
  exit 1
fi

if [[ "$worktree_path" != "$managed_root/"* ]]; then
  echo "Error: refusing to remove path outside managed root: ${worktree_path}" >&2
  exit 1
fi

if [[ ! -d "$worktree_path" ]]; then
  echo "Error: selected worktree directory does not exist: ${worktree_path}" >&2
  exit 1
fi

echo "Selected worktree:"
echo "  Branch: ${branch}"
echo "  Path:   ${worktree_path}"
echo "  State:  ${dirty_state}, ${merge_state}, ${lock_state}, PR=${pr_status}, ahead=${upstream_ahead}, behind=${upstream_behind}"
echo ""
echo "This will remove the linked worktree and its branch through vde-worktree del."
printf 'Type yes to continue: '
read -r answer

if [[ "$answer" != "yes" ]]; then
  echo "Cancelled."
  exit 0
fi

(
  cd "$repo_root"
  vde-worktree del "$branch"
)

if command -v zoxide &>/dev/null; then
  zoxide remove "$worktree_path" >/dev/null 2>&1 || true
fi

echo "Removed: ${branch} (${worktree_path})"
