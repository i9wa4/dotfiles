#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail
set -o posix

# Create a git worktree for the specified GitHub pull request(s).
# Checks out the PR branch for code review.
#
# Usage:
#   pr-worktree-create <pr_number> [pr_number2 ...]
#
# Dependencies:
#   - gh (GitHub CLI)
#   - vde-worktree
#   - repo-setup (optional)

# Check required dependencies
for cmd in gh git vde-worktree; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd command not found. Please install it." >&2
    exit 1
  fi
done

# Check arguments
if [[ $# -eq 0 ]]; then
  echo "Usage: $0 <pr_number> [pr_number2 ...]" >&2
  echo "Example: $0 123" >&2
  echo "Example: $0 123 456 789" >&2
  exit 1
fi

# Get repository root
repo_root=$(git rev-parse --show-toplevel)

fetch_pr_branch() {
  local remote=$1
  local branch=$2
  local target=$3

  if ! git fetch "${remote}" "+refs/heads/${branch}:refs/remotes/${remote}/${branch}"; then
    echo "Error: Could not fetch '${target}'." >&2
    return 1
  fi

  if ! git show-ref --verify --quiet "refs/remotes/${remote}/${branch}"; then
    echo "Error: fetched PR branch is not registered at refs/remotes/${remote}/${branch}." >&2
    return 1
  fi
}

connect_review_branch() {
  local branch=$1
  local upstream=$2
  local branch_existed=$3
  local actual_upstream

  if [[ $branch_existed == "true" ]]; then
    git branch --set-upstream-to="${upstream}" "${branch}"
    echo "* Connected local review branch: ${branch}"
  else
    git branch --track "${branch}" "${upstream}"
    echo "* Created local review branch: ${branch}"
  fi

  actual_upstream=$(git for-each-ref --format='%(upstream:short)' "refs/heads/${branch}")
  if [[ $actual_upstream != "$upstream" ]]; then
    echo "Error: local review branch upstream is '${actual_upstream}', expected '${upstream}'." >&2
    return 1
  fi
}

sync_existing_review_branch() {
  local branch=$1
  local upstream=$2
  local worktree_path=$3
  local branch_ref="refs/heads/${branch}"
  local branch_head
  local upstream_head

  if ! branch_head=$(git rev-parse --verify "${branch_ref}^{commit}"); then
    echo "Error: local review branch '${branch}' does not exist." >&2
    return 1
  fi

  if ! upstream_head=$(git rev-parse --verify "${upstream}^{commit}"); then
    echo "Error: upstream '${upstream}' does not exist." >&2
    return 1
  fi

  if [[ $branch_head == "$upstream_head" ]]; then
    echo "* Review branch is up to date: ${branch}"
    return 0
  fi

  if git merge-base --is-ancestor "${branch_ref}" "${upstream}"; then
    if [[ -n $worktree_path ]]; then
      if ! git -C "${worktree_path}" merge --ff-only "${upstream}"; then
        echo "Error: could not fast-forward '${branch}' in '${worktree_path}'." >&2
        return 1
      fi
    else
      if ! git branch --force "${branch}" "${upstream}"; then
        echo "Error: could not fast-forward local review branch '${branch}'." >&2
        return 1
      fi
    fi
    echo "* Fast-forwarded local review branch: ${branch}"
    return 0
  fi

  if git merge-base --is-ancestor "${upstream}" "${branch_ref}"; then
    echo "Error: local review branch '${branch}' has commits not in '${upstream}'; refusing to rewind." >&2
  else
    echo "Error: local review branch '${branch}' has diverged from '${upstream}'; refusing to update automatically." >&2
  fi
  echo "Please inspect the local branch before retrying." >&2
  return 1
}

# Fetch remote and update main branch
echo "-> Fetching remote..."
git fetch origin
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [[ $current_branch == "main" ]]; then
  git pull --ff-only origin main
else
  echo "* Keeping local main unchanged while ${current_branch} is checked out"
fi
echo ""

# Process each PR number
had_failure="false"
for pr_number in "$@"; do
  # Validate PR number
  if [[ ! $pr_number =~ ^[0-9]+$ ]]; then
    echo "Warning: '$pr_number' is not a valid PR number. Skipping." >&2
    echo ""
    had_failure="true"
    continue
  fi

  echo "=== Processing PR #${pr_number} ==="

  # Fetch PR branch name
  echo "-> Fetching PR #${pr_number} info..."
  if ! pr_info=$(gh pr view "${pr_number}" --json headRefName,headRepositoryOwner,headRepository,isCrossRepository --jq '[.headRefName, .headRepositoryOwner.login, .headRepository.name, .isCrossRepository] | @tsv' 2>/dev/null); then
    pr_info=""
  fi

  if [[ -z $pr_info ]]; then
    echo "Error: Could not get branch details for PR #${pr_number}." >&2
    echo "Please verify the PR exists and you have access." >&2
    echo ""
    had_failure="true"
    continue
  fi

  IFS=$'\t' read -r pr_branch pr_owner pr_repo pr_is_cross_repo <<<"$pr_info"

  if [[ -z $pr_branch || -z $pr_owner || -z $pr_repo || -z $pr_is_cross_repo ]]; then
    echo "Error: Could not parse branch details for PR #${pr_number}." >&2
    echo ""
    had_failure="true"
    continue
  fi

  echo "* PR #${pr_number} branch: ${pr_branch}"
  pr_local_branch="pr-${pr_number}-${pr_branch//\//-}"

  if [[ $pr_is_cross_repo == "true" ]]; then
    pr_remote="pr-${pr_number}-${pr_owner}-${pr_repo}"
    pr_remote_url="https://github.com/${pr_owner}/${pr_repo}.git"
    pr_fetch_target="${pr_remote}/${pr_branch}"

    if git remote get-url "${pr_remote}" >/dev/null 2>&1; then
      git remote set-url "${pr_remote}" "${pr_remote_url}"
    else
      git remote add "${pr_remote}" "${pr_remote_url}"
    fi
  else
    pr_remote="origin"
    pr_fetch_target="origin/${pr_branch}"
  fi

  existing_worktree_path=""
  if existing_worktree_path=$(vde-worktree path "${pr_local_branch}" 2>/dev/null); then
    :
  else
    existing_worktree_path=""
  fi

  local_branch_existed="false"
  if git show-ref --verify --quiet "refs/heads/${pr_local_branch}"; then
    local_branch_existed="true"
  fi

  if [[ -z $existing_worktree_path ]]; then
    echo "* Fetch target: ${pr_fetch_target}"
    fetch_pr_branch "${pr_remote}" "${pr_branch}" "${pr_fetch_target}" || {
      echo ""
      had_failure="true"
      continue
    }

    connect_review_branch "${pr_local_branch}" "${pr_fetch_target}" "${local_branch_existed}" || {
      echo ""
      had_failure="true"
      continue
    }

    if [[ $local_branch_existed == "true" ]]; then
      sync_existing_review_branch "${pr_local_branch}" "${pr_fetch_target}" "${existing_worktree_path}" || {
        echo ""
        had_failure="true"
        continue
      }
    fi
  else
    fetch_pr_branch "${pr_remote}" "${pr_branch}" "${pr_fetch_target}" || {
      echo ""
      had_failure="true"
      continue
    }

    connect_review_branch "${pr_local_branch}" "${pr_fetch_target}" "true" || {
      echo ""
      had_failure="true"
      continue
    }

    sync_existing_review_branch "${pr_local_branch}" "${pr_fetch_target}" "${existing_worktree_path}" || {
      echo ""
      had_failure="true"
      continue
    }
  fi

  if ! worktree_path=$(vde-worktree switch "${pr_local_branch}"); then
    echo "Error: Could not prepare worktree for '${pr_local_branch}'." >&2
    echo ""
    had_failure="true"
    continue
  fi

  if [[ -n $existing_worktree_path ]]; then
    echo "* Worktree already exists: ${worktree_path}"
    echo "* Branch: ${pr_local_branch} -> ${pr_fetch_target}"
  else
    echo "* Created worktree: ${worktree_path}"
    echo "* Using review branch: ${pr_fetch_target} (local: ${pr_local_branch})"

    # Copy .envrc if it exists
    if [[ -f "${repo_root}/.envrc" ]]; then
      cp "${repo_root}/.envrc" "${worktree_path}/.envrc"
      echo "* Copied .envrc to worktree"
    fi

    # Run repo-setup if available
    if command -v repo-setup &>/dev/null; then
      echo "-> Running repo-setup..."
      cd "$worktree_path"
      repo-setup
      cd - >/dev/null
    fi
  fi

  if command -v zoxide &>/dev/null; then
    zoxide add "$worktree_path"
    echo "* Added worktree to zoxide database"
  fi

  echo ""
done

if [[ $had_failure == "true" ]]; then
  echo "Error: Some PR review worktrees could not be prepared." >&2
  echo ""
  exit 1
fi

echo "* All PR review worktrees are ready."
echo ""
