#!/bin/sh
set -eu

# Refresh and query a dedicated zoxide database for linked worktrees.
# Uses vde-worktree as the source of truth for candidate paths.
#
# Usage:
#   zwt [keywords...]
#   zwt list [keywords...]
#   zwt path [keywords...]
#   zwt refresh
#   zwt add <path> [path2 ...]
#   zwt remove <path> [path2 ...]

zwt_data_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/zwt"

usage() {
  cat <<'EOF'
Usage:
  zwt [keywords...]
  zwt list [keywords...]
  zwt path [keywords...]
  zwt refresh
  zwt add <path> [path2 ...]
  zwt remove <path> [path2 ...]

Commands:
  list     Print related ghq repo roots plus managed worktree paths for the
           same matches that zwt path can resolve.
  path     Refresh the dedicated worktree database, then print a matching path.
           Uses interactive selection when no keywords are given.
  refresh  Refresh the dedicated worktree database from vde-worktree across ghq repos.
  add      Add one or more worktree paths to the dedicated database.
  remove   Remove one or more worktree paths from the dedicated database.
EOF
}

require_cmd() {
  cmd="$1"

  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: $cmd command not found. Please install it." >&2
    exit 1
  fi
}

ensure_data_dir() {
  mkdir -p "${zwt_data_dir}"
}

each_managed_repo() {
  require_cmd ghq
  ghq list -p | while IFS= read -r repo_path; do
    [ -n "${repo_path}" ] || continue
    [ -f "${repo_path}/config/vde/worktree/config.yml" ] || continue
    printf '%s\n' "${repo_path}"
  done
}

each_worktree_path() {
  require_cmd jq
  require_cmd vde-worktree

  each_managed_repo | while IFS= read -r repo_path; do
    if ! repo_json="$(
      cd "${repo_path}" &&
        vde-worktree list --json 2>/dev/null
    )"; then
      continue
    fi

    printf '%s\n' "${repo_json}" | jq -r --arg repo_path "${repo_path}" '
      .worktrees[]
      | select(.path != $repo_path)
      | .path // empty
    ' | while IFS= read -r worktree_path; do
      [ -n "${worktree_path}" ] || continue
      [ -d "${worktree_path}" ] || continue
      printf '%s\n' "${worktree_path}"
    done
  done
}

refresh_paths() {
  require_cmd zoxide
  ensure_data_dir

  each_worktree_path | while IFS= read -r worktree_path; do
    _ZO_DATA_DIR="${zwt_data_dir}" zoxide add "${worktree_path}"
  done
}

add_paths() {
  require_cmd zoxide
  ensure_data_dir

  for worktree_path in "$@"; do
    [ -d "${worktree_path}" ] || continue
    _ZO_DATA_DIR="${zwt_data_dir}" zoxide add "${worktree_path}"
  done
}

remove_paths() {
  require_cmd zoxide
  ensure_data_dir
  _ZO_DATA_DIR="${zwt_data_dir}" zoxide remove "$@"
}

matches_keywords() {
  candidate_path="$1"
  shift

  for keyword in "$@"; do
    case "${candidate_path}" in
      *"${keyword}"*) ;;
      *)
        return 1
        ;;
    esac
  done

  return 0
}

list_paths() {
  require_cmd jq
  require_cmd zoxide
  ensure_data_dir
  refresh_paths

  if ! matched_paths="$(
    _ZO_DATA_DIR="${zwt_data_dir}" zoxide query --list "$@" 2>/dev/null
  )"; then
    return 0
  fi

  each_managed_repo | while IFS= read -r repo_path; do
    if ! repo_json="$(
      cd "${repo_path}" &&
        vde-worktree list --json 2>/dev/null
    )"; then
      continue
    fi

    printed_repo=0
    printf '%s\n' "${repo_json}" | jq -r --arg repo_path "${repo_path}" '
      .worktrees[]
      | select(.path != $repo_path)
      | .path // empty
    ' | while IFS= read -r worktree_path; do
      [ -n "${worktree_path}" ] || continue
      [ -d "${worktree_path}" ] || continue

      if ! printf '%s\n' "${matched_paths}" | grep -Fx -- "${worktree_path}" >/dev/null 2>&1; then
        continue
      fi

      if [ "${printed_repo}" -eq 0 ]; then
        printf '%s\n' "${repo_path}"
        printed_repo=1
      fi

      printf '%s\n' "${worktree_path}"
    done
  done
}

query_path() {
  ensure_data_dir
  refresh_paths

  if [ "$#" -eq 0 ]; then
    _ZO_DATA_DIR="${zwt_data_dir}" zoxide query --interactive
  else
    _ZO_DATA_DIR="${zwt_data_dir}" zoxide query "$@"
  fi
}

case "${1-}" in
  "")
    query_path
    ;;
  list)
    shift
    list_paths "$@"
    ;;
  path)
    shift
    query_path "$@"
    ;;
  refresh)
    refresh_paths
    ;;
  add)
    shift
    if [ "$#" -eq 0 ]; then
      usage
      exit 1
    fi
    add_paths "$@"
    ;;
  remove)
    shift
    if [ "$#" -eq 0 ]; then
      usage
      exit 1
    fi
    remove_paths "$@"
    ;;
  -h | --help)
    usage
    ;;
  *)
    query_path "$@"
    ;;
esac
