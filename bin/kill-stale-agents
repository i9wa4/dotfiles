#!/usr/bin/env bash

# Detect and kill stale claude/codex CLI processes.
#
# A process is "stale" if none of its ancestors is an active tmux pane PID.
# This handles processes orphaned by tmux kill-session (reparented to init).
#
# Usage:
#   stale-agents          # kill stale processes
#   stale-agents --dry-run  # list without killing

dry_run=false
if [ "${1}" = "--dry-run" ]; then
  dry_run=true
fi

# Process names to detect as agents
kill_list=(
  claude
  .claude-wrapped
  claude-chill
  codex
)

active_pids=$(tmux list-panes -a -F '#{pane_pid}' 2>/dev/null)

pgrep_pattern=$(printf '%s|' "${kill_list[@]}")
pgrep_pattern=${pgrep_pattern%|}
for pid in $(pgrep -u "$(id -u)" -x "${pgrep_pattern}" 2>/dev/null); do
  orphaned=true
  current=${pid}
  while [ -n "${current}" ] && [ "${current}" != "1" ]; do
    if echo "${active_pids}" | grep -qx "${current}"; then
      orphaned=false
      break
    fi
    current=$(ps -o ppid= -p "${current}" 2>/dev/null | tr -d ' ')
  done

  if [ "${orphaned}" = true ]; then
    comm=$(ps -o comm= -p "${pid}" 2>/dev/null)
    if [ "${dry_run}" = true ]; then
      echo "Would kill: PID ${pid} (${comm})"
    else
      echo "Killing stale: PID ${pid} (${comm})"
      kill "${pid}"
      sleep 1
      if kill -0 "${pid}" 2>/dev/null; then
        echo "  SIGTERM ignored, sending SIGKILL: PID ${pid}"
        kill -9 "${pid}"
      fi
    fi
  fi
done
