#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# List managed git worktrees across ghq repositories with status metadata and
# delete merged cleanup candidates only after explicit confirmation.

usage() {
  cat <<'EOF'
Usage:
  worktree-cleanup-merged [--dry-run] [--yes]

Options:
  --dry-run  List candidates without prompting or deleting.
  --yes      Delete without prompting.
  -h, --help Show this help.
EOF
}

default_base_ref() {
  local repo="$1"
  local origin_head

  origin_head=$(git -C "$repo" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
  if [[ -n "$origin_head" ]]; then
    printf '%s\n' "$origin_head"
    return 0
  fi

  if git -C "$repo" show-ref --verify --quiet refs/remotes/origin/main; then
    printf '%s\n' "origin/main"
    return 0
  fi

  if git -C "$repo" show-ref --verify --quiet refs/heads/main; then
    printf '%s\n' "main"
    return 0
  fi

  printf '%s\n' "HEAD"
}

branch_merge_state() {
  local repo="$1"
  local branch="$2"
  local base_ref

  if [[ -z "$branch" || "$branch" == "-" ]]; then
    echo "merge?"
    return 0
  fi

  if ! git -C "$repo" show-ref --verify --quiet "refs/heads/${branch}"; then
    echo "merge?"
    return 0
  fi

  base_ref=$(default_base_ref "$repo")
  if git -C "$repo" merge-base --is-ancestor "refs/heads/${branch}" "$base_ref" 2>/dev/null; then
    echo "merged"
  else
    echo "unmerged"
  fi
}

worktree_dirty_state() {
  local worktree_path="$1"
  local status_output

  if ! status_output=$(git -C "$worktree_path" --no-optional-locks status --porcelain 2>/dev/null); then
    echo "dirty?"
    return 0
  fi

  if [[ -n "$status_output" ]]; then
    echo "dirty"
  else
    echo "clean"
  fi
}

branch_upstream() {
  local repo="$1"
  local branch="$2"
  local upstream

  if [[ -z "$branch" || "$branch" == "-" ]]; then
    echo "-"
    return 0
  fi

  upstream=$(git -C "$repo" for-each-ref --format='%(upstream:short)' "refs/heads/${branch}" 2>/dev/null || true)
  if [[ -n "$upstream" ]]; then
    echo "$upstream"
  else
    echo "-"
  fi
}

path_basename() {
  local path="$1"

  path="${path%/}"
  printf '%s\n' "${path##*/}"
}

extract_prefixed_number() {
  local value="$1"
  local prefix="$2"
  local rest
  local number

  case "$value" in
    "${prefix}-"[0-9]*)
      rest="${value#"${prefix}-"}"
      number="${rest%%-*}"
      case "$number" in
        "" | *[!0-9]*)
          return 1
          ;;
        *)
          printf '%s\n' "$number"
          ;;
      esac
      ;;
    *)
      return 1
      ;;
  esac
}

worktree_origin_label() {
  local branch="$1"
  local worktree_path="$2"
  local worktree_name
  local number

  worktree_name=$(path_basename "$worktree_path")

  if number=$(extract_prefixed_number "$worktree_name" "pr"); then
    printf 'pr-%s\n' "$number"
    return 0
  fi

  if number=$(extract_prefixed_number "$branch" "issue"); then
    printf 'issue-%s\n' "$number"
    return 0
  fi

  if number=$(extract_prefixed_number "$worktree_name" "issue"); then
    printf 'issue-%s\n' "$number"
    return 0
  fi

  echo "none"
}

list_managed_worktrees() {
  local repo="$1"
  local managed_root="$2"

  git -C "$repo" worktree list --porcelain | awk \
    -v repo_root="$repo" \
    -v managed_root="$managed_root" '
    function flush() {
      if (path != "" && path != repo_root && index(path, managed_root "/") == 1) {
        if (branch == "") {
          branch = "-"
        }
        print branch "\t" lock_state "\t" path
      }
    }

    /^worktree / {
      flush()
      path = substr($0, 10)
      branch = ""
      lock_state = "unlocked"
      next
    }

    /^branch / {
      ref = substr($0, 8)
      if (index(ref, "refs/heads/") == 1) {
        branch = substr(ref, 12)
      }
      next
    }

    /^detached$/ {
      branch = "-"
      next
    }

    /^locked/ {
      lock_state = "locked"
      next
    }

    END {
      flush()
    }
  '
}

dry_run=false
assume_yes=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=true
      ;;
    --yes)
      assume_yes=true
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

for cmd in ghq git; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: $cmd command not found. Please install it." >&2
    exit 1
  fi
done

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

repos_file="${tmpdir}/repos.tsv"
candidates_file="${tmpdir}/candidates.tsv"
inventory_file="${tmpdir}/inventory.tsv"

ghq list -p >"$repos_file"
: >"$candidates_file"
: >"$inventory_file"

while IFS= read -r repo; do
  [[ -n $repo ]] || continue
  [[ $repo != *"/.worktrees/"* ]] || continue
  [[ -d "${repo}/.git" || -f "${repo}/.git" ]] || continue
  [[ -d "${repo}/.worktrees" ]] || continue

  managed_root="${repo}/.worktrees"
  if ! raw_inventory=$(list_managed_worktrees "$repo" "$managed_root"); then
    echo "Warning: failed to inspect ${repo}" >&2
    continue
  fi

  while IFS=$'\t' read -r branch lock_state path; do
    [[ -n $path ]] || continue

    dirty_state=$(worktree_dirty_state "$path")
    merge_state=$(branch_merge_state "$repo" "$branch")
    origin_label=$(worktree_origin_label "$branch" "$path")
    upstream=$(branch_upstream "$repo" "$branch")

    cleanup_mark="・"
    merged_mark="・"
    dirty_mark="・"
    lock_mark="・"

    if [[ $merge_state == "merged" ]]; then
      merged_mark="✅"
    fi
    if [[ $dirty_state != "clean" ]]; then
      dirty_mark="⚠️"
    fi
    if [[ $lock_state != "unlocked" ]]; then
      lock_mark="🔒"
    fi
    if [[ $branch != "-" && $merge_state == "merged" && $dirty_state == "clean" && $lock_state == "unlocked" ]]; then
      cleanup_mark="🧹"
      printf '%s\t%s\t%s\n' "$repo" "$branch" "$path" >>"$candidates_file"
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$repo" \
      "$branch" \
      "$path" \
      "$cleanup_mark" \
      "$merged_mark" \
      "$dirty_mark" \
      "$lock_mark" \
      "$origin_label" \
      "$upstream" >>"$inventory_file"
  done <<<"$raw_inventory"
done <"$repos_file"

worktree_count=$(wc -l <"$inventory_file" | tr -d '[:space:]')
candidate_count=$(wc -l <"$candidates_file" | tr -d '[:space:]')

bold=""
reset=""
if [[ -t 1 ]]; then
  bold=$'\033[1m'
  reset=$'\033[0m'
fi

if [[ $worktree_count -eq 0 ]]; then
  echo "No managed worktrees found."
  exit 0
fi

echo "Managed worktrees:"
echo ""
awk -F '\t' -v bold="$bold" -v reset="$reset" '
  function shorten(value, width) {
    if (length(value) <= width) {
      return value
    }
    return substr(value, 1, width - 1) "…"
  }
  function row_style(cleanup) {
    return cleanup == "🧹" ? bold : ""
  }
  BEGIN {
    printf "%-4s  %-2s %-2s %-2s %-2s  %-15s  %-38s  %s\n",
      "No.", "C", "M", "D", "L", "Origin", "Branch", "Path"
    printf "%-4s  %-2s %-2s %-2s %-2s  %-15s  %-38s  %s\n",
      "---", "-", "-", "-", "-", "------", "------", "----"
  }
  {
    upstream = $9 == "" || $9 == "-" ? "" : " upstream=" $9
    style = row_style($4)
    end_style = style == "" ? "" : reset
    printf "%s%-4d  %-2s %-2s %-2s %-2s  %-15s  %-38s  %s%s%s\n",
      style,
      NR, $4, $5, $6, $7, $8, shorten($2, 38), $3, upstream,
      end_style
  }
' "$inventory_file"
echo ""
echo "Legend: C=cleanup candidate, M=merged, D=dirty, L=locked"
echo "        🧹=candidate, ✅=merged, ⚠️=dirty, 🔒=locked, ・=no"
if [[ -n $bold ]]; then
  echo "        candidate rows are bold"
fi
echo ""
echo "Worktrees: ${worktree_count}"

if [[ $candidate_count -eq 0 ]]; then
  echo "Cleanup candidates: 0"
  echo "No merged worktree cleanup candidates found."
  exit 0
fi

echo "Cleanup candidates: ${candidate_count}"
echo ""
awk -F '\t' '
  {
    printf "%2d. %s\n    branch: %s\n    path:   %s\n", NR, $1, $2, $3
  }
' "$candidates_file"
echo ""
echo "Total: ${candidate_count}"

if [[ $dry_run == "true" ]]; then
  exit 0
fi

if [[ $assume_yes != "true" ]]; then
  if [[ ! -t 0 ]]; then
    echo "Refusing to delete without a TTY. Re-run with --yes if this is intended." >&2
    exit 2
  fi

  printf 'Delete these merged worktrees? Type yes to continue: '
  IFS= read -r answer
  if [[ $answer != "yes" ]]; then
    echo "Cancelled."
    exit 0
  fi
fi

while IFS=$'\t' read -r repo branch path; do
  [[ -n $repo && -n $branch && -n $path ]] || continue
  echo "-> Removing ${branch} (${path})"

  if [[ $(branch_merge_state "$repo" "$branch") != "merged" ]]; then
    echo "Warning: skipped unmerged branch: ${branch}" >&2
    continue
  fi

  if [[ $(worktree_dirty_state "$path") != "clean" ]]; then
    echo "Warning: skipped dirty worktree: ${path}" >&2
    continue
  fi

  git -C "$repo" worktree remove "$path"
  if git -C "$repo" show-ref --verify --quiet "refs/heads/${branch}"; then
    git -C "$repo" branch -D "$branch"
  fi

  if command -v zoxide >/dev/null 2>&1; then
    zoxide remove "$path" >/dev/null 2>&1 || true
  fi
done <"$candidates_file"

echo "Done."
